# Taproot configuration
# Copy this file to ~/.taproot/.env and fill in values. Nothing in this file
# is required to check in - real values live outside the repo.

# -----------------------------------------------------------------------------
# Rachio controller (required - without this, zones can't be actuated)
# -----------------------------------------------------------------------------
# Get your key at https://rachio.com -> Account Settings -> Get API Key.
RACHIO_API_KEY=

# -----------------------------------------------------------------------------
# Location (required - drives forecasts, soil survey, satellite imagery)
# -----------------------------------------------------------------------------
LAT=
LON=
LOCATION_TIMEZONE=America/Denver
LOCATION_ADDRESS=

# -----------------------------------------------------------------------------
# Ambient Weather station (recommended - hyperlocal live readings)
# -----------------------------------------------------------------------------
# Create application keys at https://ambientweather.net/account.
AMBIENT_API_KEY=
AMBIENT_APP_KEY=
AMBIENT_MAC_ADDRESS=

# -----------------------------------------------------------------------------
# AquaHawk utility meter portal (optional - enables billing ground truth)
# -----------------------------------------------------------------------------
# Any municipality using the AquaHawk / UtilityHawk portal works. Your district
# is the subdomain before .aquahawk.us (e.g. City of Golden = goco).
# Account number is printed on your water bill.
AQUAHAWK_DISTRICT=
AQUAHAWK_USERNAME=
AQUAHAWK_PASSWORD=
AQUAHAWK_ACCOUNT_NUMBER=

# -----------------------------------------------------------------------------
# CoAgMet (optional - reference ET cross-validation, Colorado only)
# -----------------------------------------------------------------------------
# Nearest station ID (den01 = Denver). See https://coagmet.colostate.edu.
COAGMET_STATION=den01

# -----------------------------------------------------------------------------
# Satellite vegetation imagery (optional - Sentinel-2 NDVI)
# -----------------------------------------------------------------------------
# Free Copernicus Data Space account: https://dataspace.copernicus.eu.
COPERNICUS_EMAIL=
COPERNICUS_PASSWORD=

# -----------------------------------------------------------------------------
# AI features (optional - chat, narratives, weekly briefings, ~$0.30/yr)
# -----------------------------------------------------------------------------
AI_API_KEY=
AI_API_BASE_URL=https://api.moonshot.ai/v1
AI_MODEL=kimi-k2-thinking

# -----------------------------------------------------------------------------
# MQTT / Home Assistant (optional)
# -----------------------------------------------------------------------------
MQTT_BROKER_URL=
MQTT_TOPIC_PREFIX=taproot
HA_DISCOVERY_PREFIX=homeassistant

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
# Either n8n webhook OR direct SMTP - webhook takes precedence if both are set.
N8N_WEBHOOK_URL=
NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Web dashboard (optional)
# -----------------------------------------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=3000
WEB_UI_PASSWORD=
# Auto-detected if unset. Override: systemd | launchd | none
WEB_STARTUP_SERVICE=

# -----------------------------------------------------------------------------
# Operational toggles
# -----------------------------------------------------------------------------
# Shadow mode: decisions logged, Rachio not actuated. Use during commissioning.
SHADOW_MODE=false
# 0 = quiet, 1 = normal, 2 = verbose
DEBUG_LEVEL=1

# Path overrides (defaults land under ~/.taproot/)
DB_PATH=
STATUS_PAGE_PATH=
