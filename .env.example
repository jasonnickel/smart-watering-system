# Rachio irrigation controller
RACHIO_API_KEY=your-rachio-api-key

# Ambient Weather personal station
AMBIENT_API_KEY=your-ambient-api-key
AMBIENT_APP_KEY=your-ambient-app-key
AMBIENT_MAC_ADDRESS=your-mac-address

# Notifications
NOTIFICATION_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Optional: n8n webhook for notifications instead of direct SMTP
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/smart-water

# Database path (default: ~/.smart-water/smart-water.db)
# DB_PATH=/path/to/smart-water.db

# Shadow mode: log decisions without actuating Rachio
SHADOW_MODE=true

# Debug level: 0=errors only, 1=info, 2=debug
DEBUG_LEVEL=1

# Location for weather forecasts and local scheduling
LAT=39.73220
LON=-105.21940
LOCATION_TIMEZONE=America/Denver

# Optional: MQTT for Home Assistant integration
# MQTT_BROKER_URL=mqtt://192.168.68.110:1883
# MQTT_TOPIC_PREFIX=smart-water

# Optional: Status page output path
# STATUS_PAGE_PATH=/var/www/smart-water/status.html

# Optional: Web UI host (default 127.0.0.1)
# WEB_HOST=127.0.0.1

# Optional: Web UI port (default 3000)
# WEB_PORT=3000

# Optional: Web UI password for browser sign-in
# WEB_UI_PASSWORD=choose-a-strong-password
